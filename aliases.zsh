# ZSH
# ---
# Open ~/.zshrc
alias zc="vim ~/.zshrc"

# Source it
alias sc="source ~/.zshrc"

# Open this file 
alias za="vim ~/.oh-my-zsh/custom/aliases.zsh" 

# Source it
alias sa="source ~/.oh-my-zsh/custom/aliases.zsh"


# TMUX
# ----
# Open tmux config
alias tc="vim ~/.tmux.conf"

# List sessions
alias tls="tmux ls"

# Attach
alias ta="tmux attach"


# VIM
# ---
# Open vim
alias v="vim"

# Open .vimrc
alias vc="vim ~/.vimrc"
